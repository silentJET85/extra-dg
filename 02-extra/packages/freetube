DEFVER=1
ARCHS_SUPPORTED="amd64 arm64 armhf"
get_github_releases "FreeTubeApp/FreeTube"
if [ "${ACTION}" != prettylist ]; then
    URL=$(grep -E -m 1 "browser_download_url.*(${HOST_CPU}|${HOST_ARCH})\.deb\"" "${CACHE_FILE}" | cut -d '"' -f 4)
    VERSION_PUBLISHED=$(cut -d '/' -f 8 <<< "${URL/v/}"); VERSION_PUBLISHED="${VERSION_PUBLISHED%%-*}"
fi
PRETTY_NAME="FreeTube"
WEBSITE="https://freetubeapp.io/"
SUMMARY="An Open Source YouTube app for privacy"
